INSTALL_CMD="printf 'prstack has no install step\n'"
DEV_CMD="printf 'prstack is a CLI repo; use review, qa, and ship instead of dev\n'"
FRONTEND_BUILD_CMD="bash -n bin/prstack && bash -n ralph/loop.sh"
BACKEND_TEST_CMD="printf 'No backend test suite configured for prstack\n'"
QA_CMD="bash -n bin/prstack && bash -n ralph/loop.sh && test -f README.md && test -f templates/staff-engineer-review.md"
RALPH_ENABLED="true"
PROJECT_NAME="prstack"
PROJECT_DOMAIN="codex workflow stack"
PRODUCT_POSITIONING="Build a Codex-native workflow stack with bounded Ralph execution|Keep workflow state transparent and file-based"
PRODUCT_WHATS_WORKING="Role-aware reviews are project-configurable|Externalized workflow works against city_expansion_sim|Bounded Ralph runner is restored"
PRODUCT_GAPS="Need better report aggregation for multi-role output|Need clearer fallback messaging when external agent capacity is unavailable"
PRODUCT_DIRECTION="Favor explicit workflow state and bounded automation over hidden orchestration"
PRODUCT_PRIORITIES="Aggregate role summaries in ship output|Improve Ralph fallback messaging|Add one more role only if it changes decisions"
SECURITY_POSTURE="Local CLI workflow is low-risk|Any hosted or shared execution layer would need stronger controls"
SECURITY_FINDINGS="Ralph execution depends on external agent availability|Project configs should stay explicit and repo-local"
SECURITY_GUIDANCE="Keep commands narrow and auditable|Do not add opaque background orchestration"
SECURITY_NEXT="Improve external runner failure handling|Keep PRD mutation bounded to successful story completion"
ARCHITECTURE_STATUS="Single bash CLI with file-based state and optional Ralph assets"
ARCHITECTURE_DECISIONS="prstack remains the workflow owner|Ralph stays subordinate and bounded|Reports remain markdown"
ARCHITECTURE_RISKS="Too many roles could create process noise|Generic templates can drift from real project needs"
ARCHITECTURE_NEXT="Improve role summary aggregation|Add self-hosted backlog and ship through prstack itself"
STAFF_ENGINEERING_STATUS="Core workflow and verification are stable"
STAFF_ENGINEERING_FINDINGS="Ralph runner fallback messaging still needs work|Self-hosting backlog was previously missing"
STAFF_ENGINEERING_GUIDANCE="Keep the CLI small and verifiable|Prefer project config over hardcoded behavior"
STAFF_ENGINEERING_NEXT="Improve fallback messaging|Keep using prstack against prstack for its own upgrades"
RALPH_PRD_PATH=".agents/tasks/prd.json"
