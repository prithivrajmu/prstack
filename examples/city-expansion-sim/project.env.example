INSTALL_CMD="npm run setup:all"
DEV_CMD="npm run dev"
FRONTEND_BUILD_CMD="cd frontend && npm run build"
BACKEND_TEST_CMD="cd backend && uv run --with pytest pytest -q"
QA_CMD="cd backend && uv run python - <<'PY'
from app.server import app

client = app.test_client()
health = client.get('/health')
assert health.status_code == 200
scenarios = client.get('/scenarios')
assert scenarios.status_code == 200
payload = client.post('/sessions', json={'scenarioId': 'metro_delta_arc'}).get_json()
sid = payload['sessionId']
client.post(f'/sessions/{sid}/commands', json={'type': 'flood_barrier', 'district': 'Low Basin', 'strength': 0.14})
tick = client.post(f'/sessions/{sid}/tick', json={'steps': 3})
assert tick.status_code == 200
report = client.get(f'/sessions/{sid}/report')
assert report.status_code == 200
print('health ok')
print('scenario count', len(scenarios.get_json()['items']))
print('tick', tick.get_json()['snapshot']['tick'])
print('headline', report.get_json()['headline'])
PY"
RALPH_ENABLED="true"
PROJECT_NAME="city_expansion_sim"
PROJECT_DOMAIN="city strategy simulation"
PRODUCT_POSITIONING="Build a city-growth simulator that feels like a strategy product rather than a static demo|Primary user loop is scenario intervention, comparison, and evaluation"
PRODUCT_WHATS_WORKING="Runnable frontend and backend slices exist|Replay, save/load, reports, interventions, and evaluation are in place"
PRODUCT_GAPS="Need stronger progression beyond sandbox runs|Need richer scenario authoring and campaign structure"
PRODUCT_DIRECTION="Favor decision pressure and scenario outcomes over raw simulation complexity"
PRODUCT_PRIORITIES="Strengthen scenario authoring|Add campaign or progression structure|Deepen agent behavior where it improves choices"
SECURITY_POSTURE="Local prototype is acceptable|Hosted deployment still requires stricter controls"
SECURITY_FINDINGS="API trust boundaries should stay explicit|Retention limits must stay bounded|Input validation must remain normalized"
SECURITY_GUIDANCE="Keep localhost defaults simple|Require explicit deployment hardening before wider exposure"
SECURITY_NEXT="Add authentication and rate limiting before public deployment|Preserve normalized 4xx handling"
ARCHITECTURE_STATUS="Current shape is backend + frontend + deterministic simulation core"
ARCHITECTURE_DECISIONS="District-based world model is the shipping core|External prstack repo is the canonical workflow source"
ARCHITECTURE_RISKS="Over-expanding simulation complexity could weaken the product loop|Frontend and report contracts must stay aligned with backend schemas"
ARCHITECTURE_NEXT="Improve scenario authoring and campaign structure|Keep prstack-driven slices small and verifiable"
RALPH_PRD_PATH=".agents/tasks/prd.json"
